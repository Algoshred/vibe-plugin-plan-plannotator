{
  "name": "@vibecontrols/vibe-plugin-plan-plannotator",
  "version": "2026.527.1",
  "main": "./dist/index.js",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace --external elysia && tsc --emitDeclarationOnly --declaration --outDir ./dist && cp src/lib/installer-manifest.json dist/lib/installer-manifest.json",
    "dev": "tsc --watch",
    "lint": "eslint ./src",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "test": "bun test",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "sanity": "bun run format:check && bun run lint && bun run type:check && bun run test && bun run build"
  },
  "keywords": [
    "vibecontrols",
    "vibe",
    "vibe-plugin",
    "plan",
    "plannotator",
    "bun"
  ],
  "author": {
    "name": "Vignesh T.V",
    "email": "vignesh@burdenoff.com",
    "url": "https://github.com/tvvignesh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "description": "Plannotator plan provider for vibecontrols — wraps the upstream plannotator CLI, tunnels its UI, and configures per-AI-agent hooks.",
  "dependencies": {
    "@vibecontrols/plugin-sdk": "2026.509.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.2.10",
    "commander": "^14.0.3",
    "elysia": "^1.3.0",
    "eslint": "^9.30.1",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "elysia": ">=1.3.0"
  },
  "peerDependenciesMeta": {
    "elysia": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-plan-plannotator.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-plan-plannotator/issues"
  },
  "homepage": "https://vibecontrols.com",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "overrides": {
    "lodash": "4.18.1",
    "lodash-es": ">=4.17.21",
    "brace-expansion": ">=1.1.13"
  }
}
